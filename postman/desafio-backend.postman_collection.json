		{
			"name": "Notifications (JWT)",
			"item": [
				{
					"name": "0 — Gerar JWT (executar antes)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"function stripPadding(b) {",
									"  let s = b;",
									"  while (s.endsWith('=')) s = s.slice(0, -1);",
									"  return s;",
									"}",
									"function b64urlFromString(str) {",
									"  let b = stripPadding(CryptoJS.enc.Base64.stringify(CryptoJS.enc.Utf8.parse(str)));",
									"  return b.split('+').join('-').split('/').join('_');",
									"}",
									"function b64urlFromWordArray(wa) {",
									"  let b = stripPadding(CryptoJS.enc.Base64.stringify(wa));",
									"  return b.split('+').join('-').split('/').join('_');",
									"}",
									"const secret = pm.collectionVariables.get('JWT_SECRET');",
									"const cpf = pm.collectionVariables.get('test_cpf');",
									"const ttl = parseInt(pm.collectionVariables.get('jwt_ttl_seconds') || '3600', 10);",
									"const exp = Math.floor(Date.now() / 1000) + ttl;",
									"const iss = (pm.collectionVariables.get('JWT_ISS') || '').trim();",
									"const aud = (pm.collectionVariables.get('JWT_AUD') || '').trim();",
									"const payloadObj = { preferred_username: cpf, exp: exp };",
									"if (iss) payloadObj.iss = iss;",
									"if (aud) payloadObj.aud = aud;",
									"const headerPart = b64urlFromString(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));",
									"const payloadPart = b64urlFromString(JSON.stringify(payloadObj));",
									"const toSign = headerPart + '.' + payloadPart;",
									"const mac = CryptoJS.HmacSHA256(CryptoJS.enc.Utf8.parse(toSign), CryptoJS.enc.Utf8.parse(secret));",
									"const sigPart = b64urlFromWordArray(mac);",
									"pm.collectionVariables.set('access_token', toSign + '.' + sigPart);"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const t = pm.collectionVariables.get('access_token');",
									"pm.test('JWT gerado', () => pm.expect(t && t.split('.').length === 3).to.be.true);"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/health"
					}
				},

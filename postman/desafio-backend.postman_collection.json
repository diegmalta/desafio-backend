					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const secret = pm.collectionVariables.get('WEBHOOK_SECRET');",
									"const cpf = pm.collectionVariables.get('test_cpf');",
									"const body = JSON.stringify({",
									"  chamado_id: 'CH-2024-001234',",
									"  tipo: 'status_change',",
									"  cpf: cpf,",
									"  status_anterior: 'em_analise',",
									"  status_novo: 'em_execucao',",
									"  titulo: 'Buraco na Rua — Atualização',",
									"  descricao: 'Equipe designada para reparo na Rua das Laranjeiras, 100',",
									"  timestamp: '2024-11-15T14:30:00Z',",
									"});",
									"pm.request.body.update({ mode: 'raw', raw: body });",
									"pm.collectionVariables.set('webhook_body_duplicate', body);",
									"const mac = CryptoJS.HmacSHA256(CryptoJS.enc.Utf8.parse(body), CryptoJS.enc.Utf8.parse(secret));",
									"const hex = mac.toString(CryptoJS.enc.Hex);",
									"pm.request.headers.remove('X-Signature-256');",
									"pm.request.headers.add({ key: 'X-Signature-256', value: 'sha256=' + hex });"
								]

# Copia para `.env` e ajusta. Não comitar segredos reais.
# O serviço `app` no `docker compose` usa `env_file: .env` (segredos e opções vêm daqui).
# `DATABASE_URL` e `REDIS_ADDR` no container são forçados pelo compose para `postgres` e `redis`.

# HTTP
HTTP_ADDR=:8080

# PostgreSQL (local: localhost; docker compose: host = postgres)
DATABASE_URL=postgres://notif:notif@localhost:5432/notif?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# Webhook (HMAC do body bruto) e privacidade do CPF (HMAC separado; nunca reutilizar o mesmo segredo do webhook)
# Gera valores fortes: openssl rand -hex 32
WEBHOOK_SECRET=change-me-webhook-hmac-secret-min-16-chars
CPF_PEPPER=change-me-cpf-pepper-min-16-chars-different-from-webhook

# JWT (HS256) para /notifications — mesmo CPF_PEPPER para mapear preferred_username ao cidadão
JWT_SECRET=change-me-jwt-hs256-secret

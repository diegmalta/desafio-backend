FROM golang:1.24-alpine AS build
WORKDIR /src
RUN apk add --no-cache git ca-certificates
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/integrations-mock ./cmd/integrations-mock

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /out/integrations-mock /integrations-mock
EXPOSE 8099
USER nobody
ENTRYPOINT ["/integrations-mock"]
